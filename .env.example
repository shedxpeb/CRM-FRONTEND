# Development only — for production copy .env.production.example → .env.production
# Frontend API proxy base (Next.js rewrites /api/* to BACKEND_URL)
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_CAPABILITIES_PATH=/system/capabilities

# Backend URL for Next.js rewrites (server-side only — never expose to the browser)
BACKEND_URL=http://127.0.0.1:8000

# Image hostname for next.config.ts remote patterns (server-side only)
IMAGE_HOSTNAME=localhost

